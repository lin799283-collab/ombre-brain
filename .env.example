# ============================================================
# Ombre Brain 环境变量配置
# 复制此文件为 .env，填入真实值后运行
# ============================================================

# DeepSeek / SiliconFlow / OpenAI 兼容 API key（脱水压缩必需）
OMBRE_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 传输方式: stdio（本地）/ streamable-http（远程/Operit）
OMBRE_TRANSPORT=streamable-http

# 监听端口（默认 8000）
OMBRE_PORT=8000

# 记忆桶存储路径（默认 ./buckets）
OMBRE_BUCKETS_DIR=./buckets

# Dashboard 密码（可选，不设则首次访问时强制设置）
# OMBRE_DASHBOARD_PASSWORD=your_dashboard_password

# Webhook URL（可选，breath/dream 调用后推送事件）
# OMBRE_HOOK_URL=
# OMBRE_HOOK_SKIP=false
